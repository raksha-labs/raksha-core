# Ethereum RPC endpoints (required for indexer)
ETH_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_API_KEY
ETH_WS_URL_BACKUP=wss://mainnet.infura.io/ws/v3/YOUR_API_KEY

# Ingestion configuration
INGESTION_POLL_INTERVAL_SECS=5
INGESTION_MAX_RETRIES=20
INGESTION_RETRY_BACKOFF_MS=2000

# Detection engine configuration
DETECTION_ENGINE_USE_STREAM_MODE=true
DETECTION_ENGINE_EMIT_ALERTS=false

# Logging
RUST_LOG=info
# For debug: RUST_LOG=debug,hyper=info,tokio=info

# Database (already configured in docker-compose.yml)
# DATABASE_URL=postgresql://postgres:password@postgres:5432/defi_surv

# Redis (already configured in docker-compose.yml)
# REDIS_URL=redis://redis:6379
