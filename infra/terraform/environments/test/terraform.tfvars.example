aws_region            = "eu-west-1"
environment           = "test"
compute_mode          = "fargate_mix"
ec2_instance_type     = "t4g.medium"  # 4 GB ARM — fits all services at reduced test sizes
az_count              = 2
enable_managed_data   = false
db_instance_class     = "db.t3.micro"
db_allocated_storage  = 20
db_max_allocated_storage = 20
db_backup_retention_days = 0
db_deletion_protection   = false
db_multi_az              = false
cache_node_type          = "cache.t3.micro"
cache_num_nodes          = 1
budget_limit_usd      = 100
# To switch back to EC2-backed ECS capacity for test, set:
# compute_mode        = "ec2"
# With NAT disabled in test, the stack will place Fargate tasks in public
# subnets and assign public IPs so they can pull images and reach AWS APIs.
# Optional cost controls:
# anomaly_total_impact_absolute_usd   = 20
# enable_billing_estimated_charges_alarm = true
# billing_estimated_charges_alarm_usd = null  # null => uses budget_limit_usd
alarm_emails          = ["you@example.com"]
admin_access_mode     = "private-only"
image_tag             = "master-latest"

github_org            = "raksha-labs"
github_repo           = "raksha-core"
github_allowed_branches = ["master"]
github_allowed_environments = ["test", "stage", "prod"]

# Set this to true only in one environment/account when bootstrapping OIDC.
create_oidc_provider  = false
# oidc_provider_arn   = "arn:aws:iam::<account-id>:oidc-provider/token.actions.githubusercontent.com"

# Stream-processing services are OFF by default in test (desired_count = 0).
# Flip to true when you need to test the indexing/detection pipeline.
streams_enabled = false

# RPC WebSocket URLs for the indexer — stored as Secrets Manager secrets.
# Without this the indexer runs in mock/synthetic-data mode (health check still
# passes but no real blockchain events are indexed).
#
# 1. Create a Secrets Manager secret with JSON value:
#    { "ETH_WS_URL": "wss://eth-mainnet.g.alchemy.com/v2/<key>",
#      "BASE_WS_URL": "wss://base-mainnet.g.alchemy.com/v2/<key>" }
#    e.g.: aws secretsmanager create-secret \
#            --name raksha/test/rpc \
#            --secret-string '{"ETH_WS_URL":"wss://...","BASE_WS_URL":"wss://..."}'
#
# 2. Set the ARN (with JSON key suffix) here:
# rpc_ws_url_secret_arns = {
#   ETH_WS_URL  = "arn:aws:secretsmanager:eu-west-1:123456789012:secret:raksha/test/rpc-AbCdEf:ETH_WS_URL::"
#   BASE_WS_URL = "arn:aws:secretsmanager:eu-west-1:123456789012:secret:raksha/test/rpc-AbCdEf:BASE_WS_URL::"
# }

# service_desired_counts lets you override individual service counts on top of
# streams_enabled. Example — run only the indexer:
# service_desired_counts = {
#   indexer = 1
# }

# service_cpu_memory defaults to 128 CPU / 256 MB per service in test.
# Override only if a service is OOM-killed or needs more headroom.
# service_cpu_memory = {
#   detector = { cpu = 512, memory = 512 }
# }
