aws_region              = "eu-west-1"
environment             = "stage"
compute_mode            = "fargate_mix"
enable_managed_data     = true
budget_limit_usd        = 500
alarm_emails            = ["you@example.com"]
admin_access_mode       = "private-only"
enable_public_https     = true
public_certificate_arn  = "arn:aws:acm:eu-west-1:123456789012:certificate/replace-me"
enable_waf              = true
image_tag               = "main-abcdef0"

github_org              = "defi-surv"
github_repo             = "defi-surv-core"
github_allowed_branches = ["main", "release/*"]

create_oidc_provider    = false
# oidc_provider_arn     = "arn:aws:iam::<account-id>:oidc-provider/token.actions.githubusercontent.com"
